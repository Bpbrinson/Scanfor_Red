# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/

# ── Virtual environments ──────────────────────────────────
.venv/
venv/
env/

# ── Generated reports (recreated on every scan) ───────────
outputs/

# ── Local screenshots / data (you upload your own) ────────
# To ship a sample anyway: git add -f Dashboard_Screenshot/6_22.png
Dashboard_Screenshot/

# ── Secrets / local config (never commit real values) ─────
# Keep .env.example (the template) but ignore the real .env and any cookies/tokens.
.env
.env.*
!.env.example
*cookies*.json
*token*.json

# ── Legacy Node converter tooling ─────────────────────────
node_modules/

# ── Packaged archives ─────────────────────────────────────
*.zip

# ── Tooling / editor / OS ─────────────────────────────────
.claude/
.idea/
.vscode/
.DS_Store
Thumbs.db
