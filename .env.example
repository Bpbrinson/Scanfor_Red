# Scanfor_Red — environment configuration
# Copy this file to ".env" and fill in your values. NEVER commit your real .env.
# No credentials live here: for the VPN-restricted dashboard, log in inside your
# own Chrome and use SCREENSHOT_MODE=cdp (see README).

# Full URL of the dashboard to screenshot (including any query token).
DASHBOARD_URL=

# Where captured screenshots are saved. Inside Docker this is the mounted
# Dashboard_Screenshot volume, so captures appear on your machine too.
SCREENSHOT_OUTPUT_DIR=/app/Dashboard_Screenshot

# How to capture:
#   playwright = launch a fresh Chromium and navigate to DASHBOARD_URL
#   cdp        = connect to your already-running, logged-in Chrome over CDP
SCREENSHOT_MODE=playwright

# CDP mode only: where the running Chrome's DevTools endpoint is.
# From inside Docker, host.docker.internal points at your Mac/host.
CHROME_CDP_URL=http://host.docker.internal:9222

# Playwright mode only: run the launched browser headless (true) or visible (false).
PLAYWRIGHT_HEADLESS=false

# Extra wait after the page loads, in milliseconds, so late/polling content renders.
SCREENSHOT_WAIT_MS=5000

# Optional: path to tesseract.exe if it isn't on PATH (local non-Docker runs).
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
